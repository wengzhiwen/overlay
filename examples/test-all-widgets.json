{
  "render": {
    "width": 1920,
    "height": 1080,
    "fps": 1,
    "durationStrategy": "fixed",
    "durationMs": 1200000,
    "output": {
      "format": "mov",
      "codec": "prores",
      "proresProfile": "4444"
    }
  },
  "sync": {
    "activityOffsetMs": 0,
    "trimStartMs": 0,
    "trimEndMs": 0,
    "timezone": "Asia/Singapore"
  },
  "theme": {
