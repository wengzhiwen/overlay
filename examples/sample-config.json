{
  "render": {
    "width": 1920,
    "height": 1080,
    "fps": 1,
    "durationStrategy": "activity",
    "output": {
      "format": "mov",
      "codec": "prores",
      "proresProfile": "4444"
    }
  },
  "sync": {
    "activityOffsetMs": 0,
    "trimStartMs": 0,
    "trimEndMs": 0,
    "timezone": "Asia/Singapore"
  },
  "theme": {
    "fontFamily": "SF Pro Display, Helvetica, Arial, sans-serif",
    "colors": {
      "primary": "#ffffff",
      "secondary": "#cbd5e1",
      "accent": "#34d399",
      "text": "#ffffff",
      "muted": "#94a3b8"
    }
  },
  "widgets": [
    {
      "id": "speed-main",
      "type": "speed",
      "enabled": true,
      "x": 80,
      "y": 760,
      "scale": 0.146
    },
    {
      "id": "hr-main",
      "type": "heart-rate",
      "enabled": true,
      "x": 390,
      "y": 760,
      "scale": 0.146,
      "colorByZone": true,
      "zones": [
        { "max": 106, "color": "#94a3b8" },
        { "min": 106, "max": 133, "color": "#60a5fa" },
        { "min": 133, "max": 148, "color": "#34d399" },
        { "min": 148, "max": 158, "color": "#fbbf24" },
        { "min": 158, "max": 166, "color": "#fb923c" },
        { "min": 166, "color": "#f87171" }
      ],
      "showChart": "auto",
      "chartRange": "medium"
    },
    {
      "id": "elev-main",
      "type": "elevation",
      "enabled": true,
      "x": 700,
      "y": 760,
      "scale": 0.146,
      "showAscent": true
    },
    {
      "id": "distance-main",
      "type": "distance",
      "enabled": true,
      "x": 1010,
      "y": 760,
      "scale": 0.146
    },
    {
      "id": "time-main",
      "type": "time",
      "enabled": true,
      "x": 1320,
      "y": 760,
      "scale": 0.188,
      "mode": "both",
      "timezone": "Asia/Singapore"
    },
    {
      "id": "noodlemap-main",
      "type": "noodlemap",
      "enabled": true,
      "x": 1560,
      "y": 80,
      "scale": 0.146,
      "lineColor": "#ffffff",
      "lineWeight": "M"
    },
    {
      "id": "citymap-main",
      "type": "citymap",
      "enabled": false,
      "x": 1560,
      "y": 80,
      "scale": 0.146,
      "lineColor": "#34d399",
      "lineWeight": "M"
    }
  ],
  "debug": {
    "dumpFrameData": true,
    "dumpNormalizedActivity": true
  }
}
