{
  "render": {
    "width": 1080,
    "height": 1920,
    "fps": 1,
    "durationStrategy": "activity",
    "output": {
      "format": "mov",
      "codec": "prores",
      "proresProfile": "4444"
    }
  },
  "sync": {
    "activityOffsetMs": 0,
    "trimStartMs": 0,
    "trimEndMs": 0,
    "timezone": "Asia/Singapore"
  },
  "theme": {
    "fontFamily": "SF Pro Display, Helvetica, Arial, sans-serif",
    "colors": {
      "primary": "#ffffff",
      "secondary": "#cbd5e1",
      "accent": "#34d399",
      "text": "#ffffff",
      "muted": "#94a3b8"
    }
  },
  "widgets": [
    {
      "id": "speed-top-left",
      "type": "speed",
      "enabled": true,
      "x": 60,
      "y": 80,
      "scale": 0.333
    },
    {
      "id": "heart-rate-top-right",
      "type": "heart-rate",
      "enabled": true,
      "x": 660,
      "y": 80,
      "scale": 0.333,
      "colorByZone": true,
      "showChart": "auto",
      "chartRange": "medium"
    },
    {
      "id": "distance-bottom-right",
      "type": "distance",
      "enabled": true,
      "x": 720,
      "y": 1540,
      "scale": 0.278,
      "valueFontSize": 34,
      "labelFontSize": 16,
      "unitFontSize": 16
    },
    {
      "id": "time-bottom-right",
      "type": "time",
      "enabled": true,
      "x": 720,
      "y": 1690,
      "scale": 0.278,
      "mode": "both",
      "timezone": "Asia/Singapore",
      "valueFontSize": 34,
      "labelFontSize": 16,
      "unitFontSize": 16
    }
  ],
  "debug": {
    "dumpFrameData": true,
    "dumpNormalizedActivity": true
  }
}
