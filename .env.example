# Environment variables for `overlay worker`
# Local `overlay render` does not require a `.env` file.

# MotionO server URL
WORKER_SERVER_URL=http://localhost:5050

# Worker API key (obtained from MotionO admin)
WORKER_API_KEY=sk-your-api-key-here

# Local directory for temporary job files
# WORKER_WORK_DIR=/tmp/overlay-worker

# Heartbeat interval in seconds (default 60)
# WORKER_HEARTBEAT_INTERVAL_SEC=60

# Job poll interval in seconds (default 1)
# WORKER_POLL_INTERVAL_SEC=1

# Max concurrent render jobs
# WORKER_CONCURRENCY=1

# Upload chunk size in bytes (default 5MB)
# WORKER_CHUNK_SIZE_BYTES=5242880

# Log level: debug | info | warn | error
# LOG_LEVEL=info
