{
  "name": "overlay",
  "version": "0.1.0",
  "description": "Create overlay video by GPX or TCX file for sports vlogs.",
  "private": true,
  "type": "module",
  "bin": {
    "overlay": "./dist/cli/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsx src/cli/index.ts",
    "lint": "eslint .",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "overlay",
    "gpx",
    "tcx",
    "sports",
    "cli",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.445",
    "@remotion/renderer": "^4.0.445",
    "@sports-alliance/sports-lib": "^11.0.2",
    "@xmldom/xmldom": "^0.9.9",
    "commander": "^14.0.3",
    "fast-xml-parser": "^5.5.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remotion": "^4.0.445",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
